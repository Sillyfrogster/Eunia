---
const base = import.meta.env.BASE_URL;

const paths = [
  ["Getting started", "getting-started/"],
  ["Commands", "guides/commands/"],
  ["API reference", "reference/api/"],
  ["Examples", "examples/"],
];

const url = (path: string) => `${base}/${path}`;
---

<section class="brand-hero" aria-labelledby="eunia-tagline">
  <h1 id="_top" class="brand-logo">
    <img
      src={url("eunia-logo.png")}
      alt="Eunia"
      width="944"
      height="581"
    />
  </h1>
  <div class="hero-copy">
    <p id="eunia-tagline">A typed Discord library built for Bun.</p>
    <div class="hero-actions">
      <a class="primary-action" href={url("getting-started/")}>Get started</a>
      <a href={url("reference/api/")}>API reference <span aria-hidden="true">→</span></a>
    </div>
  </div>
</section>

<section class="install" aria-labelledby="install-heading">
  <div>
    <h2 id="install-heading">Install</h2>
    <p>Bun 1.3.14 or newer</p>
  </div>
  <code>bun add @sillyfrogster/eunia@alpha</code>
</section>

<section class="docs-paths" aria-labelledby="docs-heading">
  <div class="section-heading">
    <h2 id="docs-heading">Documentation</h2>
    <p>Start with a guide or go straight to the reference.</p>
  </div>
  <nav aria-label="Documentation paths">
    {paths.map(([label, href]) => (
      <a href={url(href)}>
        <span>{label}</span>
        <span aria-hidden="true">→</span>
      </a>
    ))}
  </nav>
</section>

<section class="coverage" aria-labelledby="coverage-heading">
  <div class="section-heading coverage-heading">
    <div>
      <h2 id="coverage-heading">Feature coverage</h2>
      <p>What has a high-level API and what does not.</p>
    </div>
    <a href={url("reference/coverage/")}>View details <span aria-hidden="true">→</span></a>
  </div>
  <div class="coverage-list">
    <article>
      <h3><span aria-hidden="true">✓</span> Ready</h3>
      <p>Commands, messages, components, guild administration, caching, gateway, and REST.</p>
    </article>
    <article>
      <h3><span aria-hidden="true">→</span> Reachable</h3>
      <p>Less common events, administrative endpoints, and Components V2 layouts.</p>
    </article>
    <article>
      <h3><span aria-hidden="true">×</span> Not included</h3>
      <p>Voice connections, codecs, players, receive pipelines, and process supervision.</p>
    </article>
  </div>
</section>

<style>
  section {
    margin-block: clamp(2.5rem, 6vw, 5rem);
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  .brand-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(16rem, 0.75fr);
    gap: clamp(1.5rem, 5vw, 4.5rem);
    align-items: center;
    margin-top: clamp(1rem, 4vw, 3rem);
    padding: clamp(1.25rem, 4vw, 3rem);
    border-radius: 0.8rem;
    background: var(--charcoal-700);
    color: var(--star-dust-500);
  }

  .brand-logo {
    line-height: 0;
  }

  .brand-logo img {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-copy {
    display: grid;
    gap: 1.5rem;
  }

  .hero-copy > p {
    max-width: 24ch;
    color: var(--star-dust-300);
    font-size: clamp(1.2rem, 2.5vw, 1.65rem);
    font-weight: 580;
    line-height: 1.45;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.25rem;
    align-items: center;
  }

  .hero-actions a {
    color: var(--star-dust-500);
    font-weight: 650;
    text-decoration: none;
  }

  .hero-actions .primary-action {
    padding: 0.7rem 1rem;
    border-radius: 0.45rem;
    background: var(--indigo-100);
    color: var(--star-dust-700);
  }

  .hero-actions a:hover,
  .hero-actions a:focus-visible {
    color: var(--steel-teal-700);
  }

  .hero-actions .primary-action:hover,
  .hero-actions .primary-action:focus-visible {
    background: var(--indigo-200);
    color: var(--star-dust-700);
  }

  .install {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.25rem;
    border-block: 1px solid var(--sl-color-gray-4);
  }

  .install h2 {
    font-size: 1rem;
  }

  .install p {
    margin-top: 0.15rem;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
  }

  .install code {
    padding: 0.75rem 0.9rem;
    overflow-x: auto;
    border-radius: 0.45rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .section-heading {
    display: flex;
    gap: 1.5rem;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 1.4rem;
  }

  .section-heading h2 {
    font-size: var(--sl-text-h2);
  }

  .section-heading p {
    max-width: 34rem;
    color: var(--sl-color-gray-2);
    line-height: 1.6;
  }

  .docs-paths nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--sl-color-gray-4);
  }

  .docs-paths nav a {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    border-bottom: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-white);
    font-weight: 650;
    text-decoration: none;
  }

  .docs-paths nav a:nth-child(odd) {
    padding-right: clamp(1.5rem, 5vw, 4rem);
  }

  .docs-paths nav a:nth-child(even) {
    padding-left: clamp(1.5rem, 5vw, 4rem);
    border-left: 1px solid var(--sl-color-gray-4);
  }

  .docs-paths nav a:hover,
  .docs-paths nav a:focus-visible,
  .coverage-heading a:hover,
  .coverage-heading a:focus-visible {
    color: var(--sl-color-accent);
  }

  .coverage-heading a {
    flex: none;
    color: var(--sl-color-accent-high);
    font-weight: 650;
  }

  .coverage-list {
    border-top: 1px solid var(--sl-color-gray-4);
  }

  .coverage-list article {
    display: grid;
    grid-template-columns: minmax(8rem, 0.35fr) minmax(0, 1.65fr);
    gap: 1.5rem;
    padding-block: 1.2rem;
    border-bottom: 1px solid var(--sl-color-gray-4);
  }

  .coverage-list h3 {
    display: flex;
    gap: 0.55rem;
    align-items: baseline;
    font-size: 1rem;
  }

  .coverage-list h3 span {
    width: 1.15rem;
    color: var(--steel-teal-500);
  }

  .coverage-list article:last-child h3 span {
    color: var(--foggy-100);
  }

  .coverage-list p {
    color: var(--sl-color-gray-2);
    line-height: 1.6;
  }

  @media (max-width: 50rem) {
    .brand-hero {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .brand-logo img {
      max-width: 34rem;
      margin-inline: auto;
    }

    .hero-copy {
      justify-items: center;
      text-align: center;
    }

    .install,
    .section-heading {
      align-items: start;
      flex-direction: column;
    }

    .install {
      gap: 0.8rem;
    }

    .install code {
      max-width: 100%;
    }
  }

  @media (max-width: 34rem) {
    .docs-paths nav {
      grid-template-columns: 1fr;
    }

    .docs-paths nav a:nth-child(odd),
    .docs-paths nav a:nth-child(even) {
      padding-inline: 0;
      border-left: 0;
    }

    .coverage-list article {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>

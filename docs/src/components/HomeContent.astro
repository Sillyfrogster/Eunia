---
const base = import.meta.env.BASE_URL;

const ready = [
  ["Commands", "Slash and prefix commands, groups, autocomplete, guards, cooldowns, and deferral."],
  ["Messages", "Messages, embeds, polls, files, reactions, pins, buttons, selects, and modals."],
  ["State", "Bounded memory with Redis, Valkey, and custom adapter support."],
  ["Transport", "Gateway resume and sharding with rate-aware REST requests and bounded retries."],
];

const reachable = [
  ["Less common events", "Receive every dispatch as a raw typed payload when no structure event exists."],
  ["Administrative endpoints", "Use client.rest for audit logs, scheduled events, auto moderation, and stickers."],
  ["Components V2", "Send typed payloads directly; layout-specific helpers are not included yet."],
];

const excluded = [
  ["Voice", "Connections, codecs, players, and receive pipelines are outside this release."],
  ["Process supervision", "Eunia does not run or coordinate your application processes."],
];
---

<section class="home-intro" aria-labelledby="why-eunia">
  <div>
    <h2 id="why-eunia">Install</h2>
    <p>
      Eunia requires Bun 1.3.14 or newer. Install the current alpha release from npm.
    </p>
  </div>
  <pre aria-label="Install Eunia"><code>bun add @sillyfrogster/eunia@alpha</code></pre>
</section>

<section class="paths" aria-labelledby="choose-a-path">
  <h2 id="choose-a-path">Guides</h2>
  <div class="path-list">
    <a href={`${base}getting-started/`}>
      <strong>Getting started</strong>
      <span>Install Eunia, connect, and publish a development command.</span>
      <span aria-hidden="true">→</span>
    </a>
    <a href={`${base}guides/commands/`}>
      <strong>Commands</strong>
      <span>Add options, groups, permissions, cooldowns, and component listeners.</span>
      <span aria-hidden="true">→</span>
    </a>
    <a href={`${base}guides/cache/`}>
      <strong>Caching</strong>
      <span>Use bounded memory alone or add Redis, Valkey, or your own adapter.</span>
      <span aria-hidden="true">→</span>
    </a>
    <a href={`${base}guides/modules/`}>
      <strong>Modules</strong>
      <span>Own services and lifecycle work without changing the client core.</span>
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<section class="coverage" aria-labelledby="coverage-heading">
  <div class="coverage-heading">
    <div>
      <h2 id="coverage-heading">Feature coverage</h2>
      <p>Eunia is in alpha. This summary tracks full, lower-level, and unsupported areas.</p>
    </div>
    <a href={`${base}reference/coverage/`}>Full coverage details →</a>
  </div>

  <div class="coverage-group ready">
    <h3><span aria-hidden="true">✓</span> Ready</h3>
    <div>
      {ready.map(([name, detail]) => (
        <article>
          <strong>{name}</strong>
          <p>{detail}</p>
        </article>
      ))}
    </div>
  </div>

  <div class="coverage-group reachable">
    <h3><span aria-hidden="true">↗</span> Reachable</h3>
    <div>
      {reachable.map(([name, detail]) => (
        <article>
          <strong>{name}</strong>
          <p>{detail}</p>
        </article>
      ))}
    </div>
  </div>

  <div class="coverage-group excluded">
    <h3><span aria-hidden="true">×</span> Not included</h3>
    <div>
      {excluded.map(([name, detail]) => (
        <article>
          <strong>{name}</strong>
          <p>{detail}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    margin-block: clamp(3rem, 6vw, 5rem);
  }

  h2,
  h3,
  p {
    margin: 0;
  }

  h2 {
    font-size: var(--sl-text-h2);
  }

  .home-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.75fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: end;
  }

  .home-intro p,
  .coverage-heading p {
    max-width: 38rem;
    margin-top: 0.8rem;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-base);
    line-height: 1.65;
  }

  .home-intro pre {
    margin: 0;
    padding: 1rem 1.15rem;
    overflow-x: auto;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.6rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    font-size: 0.88rem;
  }

  .paths h2 {
    margin-bottom: 1.5rem;
  }

  .path-list {
    border-top: 1px solid var(--sl-color-gray-4);
  }

  .path-list a {
    display: grid;
    grid-template-columns: minmax(10rem, 0.7fr) minmax(16rem, 1.3fr) auto;
    gap: 1.5rem;
    align-items: center;
    padding-block: 1.3rem;
    border-bottom: 1px solid var(--sl-color-gray-4);
    color: var(--sl-color-white);
    text-decoration: none;
    transition: color 160ms cubic-bezier(0.22, 1, 0.36, 1), padding 160ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .path-list a:hover,
  .path-list a:focus-visible {
    padding-inline: 0.5rem;
    color: var(--sl-color-accent);
  }

  .path-list a span:nth-child(2) {
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }

  .coverage {
    padding: clamp(1.5rem, 4vw, 3rem);
    border-radius: 0.8rem;
    background: var(--sl-color-gray-6);
  }

  .coverage-heading {
    display: flex;
    gap: 2rem;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .coverage-heading a {
    flex: none;
    color: var(--sl-color-accent-high);
    font-weight: 650;
  }

  .coverage-group {
    display: grid;
    grid-template-columns: minmax(8rem, 0.35fr) minmax(0, 1.65fr);
    gap: 1.5rem;
    padding-block: 1.6rem;
    border-top: 1px solid var(--sl-color-gray-3);
  }

  .coverage-group h3 {
    display: flex;
    gap: 0.55rem;
    align-items: baseline;
    font-size: 1rem;
  }

  .coverage-group h3 span {
    width: 1.25rem;
    color: var(--sl-color-accent);
  }

  .coverage-group > div {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.6rem 2.5rem;
  }

  .coverage-group article p {
    margin-top: 0.35rem;
    color: var(--sl-color-gray-2);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .reachable h3 span {
    color: var(--steel-teal-500);
  }

  .excluded h3 span {
    color: var(--foggy-100);
  }

  @media (max-width: 50rem) {
    .home-intro,
    .coverage-group {
      grid-template-columns: 1fr;
    }

    .path-list a {
      grid-template-columns: 1fr auto;
      gap: 0.35rem 1rem;
    }

    .path-list a span:nth-child(2) {
      grid-column: 1 / -1;
    }

    .coverage-heading {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (max-width: 34rem) {
    .coverage-group > div {
      grid-template-columns: 1fr;
    }
  }
</style>

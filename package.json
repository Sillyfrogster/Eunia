{
  "name": "@sillyfrogster/eunia",
  "version": "0.2.0-alpha.1",
  "description": "A modular TypeScript Discord library built for Bun",
  "keywords": ["discord", "discord-api", "bot", "bun", "typescript"],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "author": "Sillyfrogster",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sillyfrogster/Eunia.git"
  },
  "homepage": "https://sillyfrogster.github.io/Eunia/",
  "bugs": {
    "url": "https://github.com/Sillyfrogster/Eunia/issues"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts --platform node --target esnext",
    "check": "bun run typecheck && bun test --parallel=1",
    "coverage": "bun run scripts/coverage.ts",
    "docs:build": "astro build --root docs",
    "docs:dev": "astro dev --root docs",
    "docs:preview": "astro preview --root docs",
    "examples:check": "tsc -p apps/slash-commands/tsconfig.json && tsc -p apps/component-listeners/tsconfig.json",
    "prepack": "bun run build",
    "test": "bun test --parallel=1",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.41.3",
    "@fontsource-variable/onest": "^5.3.0",
    "@types/bun": "^1.3.14",
    "astro": "^7.1.3",
    "tsdown": "^0.22.12",
    "typescript": "^5.5.0"
  }
}

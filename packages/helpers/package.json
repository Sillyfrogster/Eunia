{
  "name": "@eunia/helpers",
  "version": "0.1.0-alpha.1",
  "description": "Opt-in content templates for Eunia",
  "type": "module",
  "engines": { "bun": ">=1.3.14" },
  "types": "./src/index.ts",
  "sideEffects": false,
  "files": ["src", "README.md"],
  "publishConfig": { "access": "public" },
  "exports": {
    ".": { "types": "./src/index.ts", "default": "./src/index.ts" }
  },
  "dependencies": {
    "@eunia/client": "workspace:*",
    "@eunia/types": "workspace:*"
  }
}

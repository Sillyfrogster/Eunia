# Bun loads this file without another package.
DISCORD_TOKEN=paste-your-token-here

# Set a development guild to publish slash commands to while developing.
# Leave this empty to skip automatic command publishing.
DISCORD_GUILD_ID=

# debug | info | warn | error | silent. Unset means silent: the library logs
# nothing unless this is set or the app injects its own logger.
EUNIA_LOG=info
